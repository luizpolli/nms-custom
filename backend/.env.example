# Backend Environment

APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-real-secret-key
CREDENTIAL_ENCRYPTION_KEY=
CREDENTIAL_ENCRYPTION_IV=
DATABASE_URL=postgresql+asyncpg://nms:nms_secret@postgres:5432/nms
REDIS_URL=redis://redis:6379/0
SNMP_DEFAULT_COMMUNITY=public
SNMP_VERSION=v2c
ALLOWED_HOSTS=localhost,127.0.0.1,::1,testserver,app,backend
CORS_ORIGINS=["http://localhost:5173"]
DISCOVERY_CHUNK_SIZE=256
DISCOVERY_POLL_INTERVAL=60
DISCOVERY_TIMEOUT=5
POLL_INTERVAL=60
POLL_TIMEOUT=10
POLL_WORKERS=4
ALARM_POLL_INTERVAL=30
ALARM_WORKERS=2
TOPOLOGY_POLL_INTERVAL=300

# --- Body-size limits (P2) ---
# Toggle body-size limit middleware (default: true)
BODY_SIZE_LIMIT_ENABLED=true
# Default maximum body size for ordinary API POST/PUT/PATCH requests (MB)
MAX_REQUEST_BODY_MB=1
# Larger cap for bulk endpoints (bulk alarms, device import/export, telemetry ingest)
MAX_BULK_REQUEST_BODY_MB=4
# Cap for MIB file uploads (should be >= MIB_UPLOAD_MAX_BYTES / 1048576)
MAX_MIB_UPLOAD_BODY_MB=10

# --- Rate limits (P0, already enabled) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=auto
RATE_LIMIT_DEFAULT=120/60
RATE_LIMIT_SENSITIVE=20/60
RATE_LIMIT_ANONYMOUS=30/60

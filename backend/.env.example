# Backend Environment

APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-real-secret-key
CREDENTIAL_ENCRYPTION_KEY=
CREDENTIAL_ENCRYPTION_IV=
DATABASE_URL=postgresql+asyncpg://nms:nms_secret@postgres:5432/nms
REDIS_URL=redis://redis:6379/0
SNMP_DEFAULT_COMMUNITY=public
SNMP_VERSION=v2c
ALLOWED_HOSTS=*
CORS_ORIGINS=["http://localhost:5173"]
DISCOVERY_CHUNK_SIZE=256
DISCOVERY_POLL_INTERVAL=60
DISCOVERY_TIMEOUT=5
POLL_INTERVAL=60
POLL_TIMEOUT=10
POLL_WORKERS=4
ALARM_POLL_INTERVAL=30
ALARM_WORKERS=2
TOPOLOGY_POLL_INTERVAL=300

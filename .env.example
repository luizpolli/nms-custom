# NMS_Custom Environment Variables

# ---- Postgres ----
POSTGRES_USER=nms
POSTGRES_PASSWORD=nms_secret
POSTGRES_DB=nms
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- App / Backend ----
BACKEND_PORT=8000
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-real-secret-key
CREDENTIAL_ENCRYPTION_KEY=change-me-to-32-byte-key-hex
CREDENTIAL_ENCRYPTION_IV=change-me-to-16-byte-iv-hex
SNMP_DEFAULT_COMMUNITY=public
SNMP_VERSION=v2c
ALLOWED_HOSTS=*
CORS_ORIGINS=["http://localhost:5173"]

# ---- Discovery ----
DISCOVERY_CHUNK_SIZE=256
DISCOVERY_POLL_INTERVAL=60
DISCOVERY_TIMEOUT=5

# ---- Polling ----
POLL_INTERVAL=60
POLL_TIMEOUT=10
POLL_WORKERS=4

# ---- Alarms ----
ALARM_POLL_INTERVAL=30
ALARM_WORKERS=2

# ---- Topology ----
TOPOLOGY_POLL_INTERVAL=300
LLDP_INTERVAL=120
CDP_INTERVAL=120

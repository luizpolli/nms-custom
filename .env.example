# NMS_Custom Environment Variables

# ---- Postgres ----
POSTGRES_USER=nms
POSTGRES_PASSWORD=nms_secret
POSTGRES_DB=nms
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- App / Backend ----
BACKEND_PORT=8000
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-real-secret-key
CREDENTIAL_ENCRYPTION_KEY=change-me-to-32-byte-key-hex
CREDENTIAL_ENCRYPTION_IV=change-me-to-16-byte-iv-hex
SNMP_DEFAULT_COMMUNITY=public
SNMP_VERSION=v2c
ALLOWED_HOSTS=localhost,127.0.0.1,::1,testserver,app,backend
CORS_ORIGINS=["https://localhost:5173"]

# ---- API Auth / RBAC ----
# Keep disabled only for local single-user development.
API_AUTH_ENABLED=false
# Comma-separated high-entropy keys. Example only; replace before use.
# Production may use sha256$<hex-digest> entries instead of plaintext keys.
API_KEYS=change-me-admin-key,change-me-aiops-key
# Optional per-key role mapping. Unmapped keys default to admin for backward compatibility.
# Role-map keys may also use the same sha256$<hex-digest> form.
API_KEY_ROLES=change-me-admin-key:admin,change-me-aiops-key:ai-ops
ROOT_WEB_LOGIN_ENABLED=false
MAX_PARALLEL_SESSIONS=5
IDLE_TIMEOUT_MINUTES=30

# ---- HTTPS / TLS ----
HTTPS_ENABLED=true
HTTPS_REDIRECT_ENABLED=true
TLS_MIN_VERSION=TLSv1.3
TLS_CERT_FILE=/certs/server.crt
TLS_KEY_FILE=/certs/server.key
TLS_CA_FILE=
FRONTEND_PORT=5173

# ---- Discovery ----
DISCOVERY_CHUNK_SIZE=256
DISCOVERY_POLL_INTERVAL=60
DISCOVERY_TIMEOUT=5

# ---- Polling ----
POLL_INTERVAL=60
POLL_TIMEOUT=10
POLL_WORKERS=4

# ---- Alarms ----
ALARM_POLL_INTERVAL=30
ALARM_WORKERS=2

# ---- Ingestion receivers ----
SYSLOG_BIND_PORT=5514
TRAP_PORT=1162
TELEMETRY_BIND_PORT=57400
TELEMETRY_TRANSPORT=gnmi-json

# ---- AI Ops LLM assistant ----
# Disabled by default. The built-in null provider is deterministic and does not call an external API.
AI_OPS_LLM_ENABLED=false
AI_OPS_LLM_PROVIDER=null
AI_OPS_MAX_ALARMS=20
AI_OPS_MAX_KPIS=20
AI_OPS_MAX_QUESTION_CHARS=1000
AI_OPS_MAX_ANSWER_CHARS=2000
AI_OPS_ASSISTANT_ALLOWED_ROLES=admin,ai-ops

# ---- Upload limits ----
MIB_UPLOAD_MAX_BYTES=5242880
MIB_ALLOWED_EXTENSIONS=[".mib",".my",".txt"]

# ---- SSH security ----
SSH_KNOWN_HOSTS_PATH=
SSH_DISABLE_HOST_KEY_CHECKING=false
# Optional comma-separated regex allow-list. Empty allows all commands for dev.
# Example: COMMAND_ALLOWLIST=show\s+.*,ping\s+.*
COMMAND_ALLOWLIST=

# ---- Topology ----
TOPOLOGY_POLL_INTERVAL=300
LLDP_INTERVAL=120
CDP_INTERVAL=120

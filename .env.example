# NMS_Custom Environment Variables

# ---- Postgres ----
POSTGRES_USER=nms
POSTGRES_PASSWORD=nms_secret
POSTGRES_DB=nms
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---- App / Backend ----
BACKEND_PORT=8000
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-real-secret-key
CREDENTIAL_ENCRYPTION_KEY=change-me-to-32-byte-key-hex
CREDENTIAL_ENCRYPTION_IV=change-me-to-16-byte-iv-hex
SNMP_DEFAULT_COMMUNITY=public
SNMP_VERSION=v2c
ALLOWED_HOSTS=localhost,127.0.0.1,::1,testserver,app,backend
CORS_ORIGINS=["https://localhost:5173"]

# ---- API Auth / RBAC ----
# Keep disabled ONLY for local single-user development. Always enable in production.
API_AUTH_ENABLED=false

# API_KEYS — comma-separated bearer tokens sent in the X-API-Key header.
#
# Plaintext form (dev/local only — never commit real keys):
#   API_KEYS=my-local-dev-key
#
# Prehashed form (RECOMMENDED for production):
#   Generate: RAW=$(openssl rand -hex 32)
#             HASH=$(echo -n "$RAW" | sha256sum | awk '{print "sha256$"$1}')
#   Store $HASH here; give $RAW to the caller.
#
#   API_KEYS=sha256$7b8d2fae...3c4a01,sha256$9e1a4c88...0f2b77
#
# See docs/API_KEY_MANAGEMENT.md for the full lifecycle guide.
API_KEYS=change-me-admin-key,change-me-aiops-key

# API_KEY_ROLES — per-key role assignments.
# Format: <key-or-hash>:<role>[,<key-or-hash>:<role>...]
# Available roles: admin | operator | read-only | ai-ops
# Keys absent from this map default to 'admin' (backward compat).
# Hashed keys in API_KEYS MUST use the same sha256$<hex> form here.
#
# Example (hashed):
#   API_KEY_ROLES=sha256$7b8d2fae...3c4a01:admin,sha256$9e1a4c88...0f2b77:ai-ops
API_KEY_ROLES=change-me-admin-key:admin,change-me-aiops-key:ai-ops
ROOT_WEB_LOGIN_ENABLED=false
MAX_PARALLEL_SESSIONS=5
IDLE_TIMEOUT_MINUTES=30

# ---- HTTPS / TLS ----
HTTPS_ENABLED=true
HTTPS_REDIRECT_ENABLED=true
TLS_MIN_VERSION=TLSv1.3
TLS_CERT_FILE=/certs/server.crt
TLS_KEY_FILE=/certs/server.key
TLS_CA_FILE=
FRONTEND_PORT=5173

# ---- Rate limiting ----
# Toggle the per-request rate limit middleware.
RATE_LIMIT_ENABLED=true
# Backend: auto (Redis with memory fallback), redis (strict), memory (single-worker only).
RATE_LIMIT_BACKEND=auto
# Format "<count>/<window-seconds>". default = /api/* authenticated requests.
RATE_LIMIT_DEFAULT=120/60
# Sensitive bucket for commands, credentials, settings/users, mibs, ai-ops, and unauth writes.
RATE_LIMIT_SENSITIVE=20/60
# Anonymous bucket for unauthenticated GETs to /api/*.
RATE_LIMIT_ANONYMOUS=30/60
# Comma-separated path prefixes that bypass rate limiting (health, metrics, docs).
RATE_LIMIT_EXEMPT_PATHS=/api/health,/health,/metrics,/api/docs,/api/openapi,/api/redoc

# ---- Discovery ----
DISCOVERY_CHUNK_SIZE=256
DISCOVERY_POLL_INTERVAL=60
DISCOVERY_TIMEOUT=5

# ---- Polling ----
POLL_INTERVAL=60
POLL_TIMEOUT=10
POLL_WORKERS=4

# ---- Alarms ----
ALARM_POLL_INTERVAL=30
ALARM_WORKERS=2

# ---- Ingestion receivers ----
SYSLOG_BIND_PORT=5514
TRAP_PORT=1162
TELEMETRY_BIND_PORT=57400
TELEMETRY_TRANSPORT=gnmi-json

# ---- AI Ops LLM assistant ----
# Disabled by default. The built-in null provider is deterministic and does not call an external API.
AI_OPS_LLM_ENABLED=false
AI_OPS_LLM_PROVIDER=null
# Provider options: null, openai-compatible. Keep null unless egress/retention is approved.
AI_OPS_LLM_API_KEY=
AI_OPS_LLM_BASE_URL=https://api.openai.com/v1
AI_OPS_LLM_MODEL=gpt-4o-mini
AI_OPS_LLM_TIMEOUT_SECONDS=30
AI_OPS_MAX_ALARMS=20
AI_OPS_MAX_KPIS=20
AI_OPS_MAX_QUESTION_CHARS=1000
AI_OPS_MAX_ANSWER_CHARS=2000
AI_OPS_ASSISTANT_ALLOWED_ROLES=admin,ai-ops

# ---- Upload limits ----
MIB_UPLOAD_MAX_BYTES=5242880
MIB_ALLOWED_EXTENSIONS=[".mib",".my",".txt"]

# ---- SSH security ----
SSH_KNOWN_HOSTS_PATH=
SSH_DISABLE_HOST_KEY_CHECKING=false

# COMMAND_ALLOWLIST — comma-separated Python regex patterns.
# A device command (via POST /api/devices/{id}/exec) is permitted only when it
# fully matches at least one pattern (re.fullmatch). Empty = allow all (dev default).
#
# Read-only Cisco IOS / IOS-XR / NX-OS (recommended production baseline):
#   COMMAND_ALLOWLIST=show\s+.*,ping\s+[\w.:]+,traceroute\s+[\w.:]+,dir\s+.*,admin\s+show\s+.*
#
# Minimal show-only:
#   COMMAND_ALLOWLIST=show\s+.*
#
# Allow nothing (lockout all exec; useful for read-only deployments):
#   COMMAND_ALLOWLIST=(?!)
#
# See docs/API_KEY_MANAGEMENT.md §5 for the full pattern reference.
COMMAND_ALLOWLIST=

# ---- Topology ----
TOPOLOGY_POLL_INTERVAL=300
LLDP_INTERVAL=120
CDP_INTERVAL=120
